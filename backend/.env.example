# ── AI ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
# Get free at: https://console.groq.com

# ── MAPS & ROUTING ───────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
# Get at: https://console.cloud.google.com
# Enable: Directions API + Maps JavaScript API
# Note: App works WITHOUT this key (uses Haversine fallback)

# ── WEATHER ──────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_key_here
# Free tier at: https://openweathermap.org/api
# Plan needed: Free (Current Weather Data)

# ── INDIA GOVERNMENT DATA ────────────────────────────
DATA_GOV_IN_API_KEY=your_data_gov_in_key_here
# Free at: https://data.gov.in/user/register
# Note: App works WITHOUT this (uses ReliefWeb fallback)

# ── DATABASE ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/saathi
# Or use: mongodb+srv://... for MongoDB Atlas (free tier)

# ── SERVER ───────────────────────────────────────────
PORT=5000
NODE_ENV=development